# SHROOOMS — Environment Variables Template
# Copy this file to '.env' and populate with production credentials.
# DO NOT commit real secrets or credentials to Git.

# API Base URL for custom server routes (e.g. backend/express server)
REACT_APP_API_BASE_URL=

# Supabase database configuration credentials
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
